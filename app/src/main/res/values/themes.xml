<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Note" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/wave_behind_main</item>
        <item name="colorPrimaryVariant">@color/wave_front_main</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/wave_behind_edit_note</item>
        <item name="colorSecondaryVariant">@color/wave_front_edit_note</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:popupMenuStyle">@style/CustomPopupMenu</item>

        <item name="android:textAppearanceLargePopupMenu">@style/CustomPopupTextAppearance</item>
    </style>

    <style name="CustomPopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_bg</item>
        <item name="android:dropDownVerticalOffset">4dp</item>
    </style>

    <style name="CustomPopupTextAppearance" parent="TextAppearance.AppCompat.Widget.PopupMenu.Large">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>