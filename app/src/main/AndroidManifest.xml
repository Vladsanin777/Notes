<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Base.Theme.Notes">
        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.MainActivity"
            android:exported="true"
            tools:ignore="NewApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".NewNote"
            android:theme="@style/Theme.NewNote"
            android:exported="false"
            tools:ignore="NewApi"/>
        <activity
            android:name=".EditNote"
            android:theme="@style/Theme.EditNote"
            android:exported="false"
            tools:ignore="NewApi"/>
        <activity
            android:name=".History"
            android:theme="@style/Theme.History"
            android:exported="false"
            tools:ignore="NewApi"/>
        <activity
            android:name=".NotesDeleted"
            android:theme="@style/Theme.NotesDeleted"
            android:exported="false"
            tools:ignore="NewApi"/>
        <activity
            android:name=".NotesTemplate"
            android:theme="@style/Theme.NotesTemplate"
            android:exported="false"
            tools:ignore="NewApi"/>
        <activity
            android:name=".NotesHeads"
            android:theme="@style/Theme.NotesHeads"
            android:exported="false"
            tools:ignore="NewApi"/>
    </application>

</manifest>